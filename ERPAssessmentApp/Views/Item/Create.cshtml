@model ERPAssessmentApp.Models.Item

@{
    ViewData["Title"] = "Add Item";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-success text-white">
                    <h4 class="mb-0">Add New Input Item</h4>
                </div>
                <div class="card-body p-4">
                    <div asp-validation-summary="All" class="alert alert-danger" style="display: @(ViewData.ModelState.IsValid ? "none" : "block")"></div>
                    <form asp-action="Create">
                        <div class="mb-3">
                            <label asp-for="ItemName" class="form-label">Item Name</label>
                            <input asp-for="ItemName" class="form-control" required />
                        </div>
                        <div class="mb-4">
                            <label asp-for="Weight" class="form-label">Weight</label>
                            <input asp-for="Weight" type="number" step="0.01" class="form-control" required />
                        </div>
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                            <button type="submit" class="btn btn-success">Save Item</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>