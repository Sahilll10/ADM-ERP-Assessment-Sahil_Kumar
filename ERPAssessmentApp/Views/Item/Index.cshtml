@model IEnumerable<ERPAssessmentApp.Models.Item>

@{
    ViewData["Title"] = "Items List";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Item Inventory</h2>
        <a asp-action="Create" class="btn btn-success">Add New Item</a>
    </div>

    <form asp-action="Index" method="get" class="mb-4">
        <div class="input-group">
            <input type="text" name="searchString" class="form-control" placeholder="Search by item name..." />
            <button type="submit" class="btn btn-outline-primary">Search</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Clear</a>
        </div>
    </form>

    <div class="table-responsive">
        <table class="table table-bordered table-hover shadow-sm">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Item Name</th>
                    <th>Weight</th>
                    <th>Status</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="align-middle">@item.ItemId</td>
                            <td class="align-middle">@item.ItemName</td>
                            <td class="align-middle">@item.Weight</td>
                            <td class="align-middle">
                                @if (item.IsProcessed)
                                {
                                    <span class="badge bg-secondary">Processed</span>
                                }
                                else
                                {
                                    <span class="badge bg-primary">Raw</span>
                                }
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
        
                                    @if (!item.IsProcessed)
                                    {
                                        <a asp-action="Process" asp-route-id="@item.ItemId" class="btn btn-sm btn-info text-white">Process</a>
                                    }

                                    <a asp-action="Edit" asp-route-id="@item.ItemId" class="btn btn-sm btn-warning">Edit</a>
        
                                    <form asp-action="Delete" asp-route-id="@item.ItemId" method="post" onsubmit="return confirm('Are you sure you want to delete this item?');">
                                        <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                    </form>
        
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">No items found in the inventory.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>