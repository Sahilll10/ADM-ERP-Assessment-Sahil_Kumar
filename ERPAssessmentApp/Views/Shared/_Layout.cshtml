<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ADM Systems ERP</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4 shadow-sm">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Item" asp-action="Index">
                    <img src="https://d8it4huxumps7.cloudfront.net/uploads/images/150x150/69b5921615345_organisation_image-j026nW1NgL11195776072Fj73N91ds.png?d=200x200"
                         alt="ADM Logo"
                         style="max-height: 35px; width: auto;"
                         class="me-2 bg-white rounded-circle p-1" />
                    <span class="fw-bold tracking-tight">ADM Systems <span class="text-primary">ERP</span></span>
                </a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mobileMenu">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="collapse navbar-collapse" id="mobileMenu">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Item" asp-action="Index">Item Inventory</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Item" asp-action="Tree">Hierarchy Tree</a>
                        </li>
                    </ul>
                    
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link text-danger fw-bold" asp-controller="Account" asp-action="Logout">
                                <i class="bi bi-box-arrow-right"></i> Logout
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted bg-white border-top py-3 mt-auto">
        <div class="container text-center">
            <small>&copy; 2026 - ADM Systems Solutions - ERP Assessment Project</small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>